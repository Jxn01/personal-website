---
import "@fontsource-variable/space-grotesk";
import "@fontsource-variable/jetbrains-mono";
import "@/styles/global.css";
import type { Locale } from "@/i18n";
import { getDict } from "@/i18n";
import { BASE, withBase } from "@/lib/url";

interface Props {
  locale: Locale;
  /** Override <title> (404, status). */
  title?: string;
  description?: string;
  /** Error pages: red favicon, no needle drop. */
  variant?: "default" | "error";
}

const { locale, title, description, variant = "default" } = Astro.props;
const dict = getDict(locale);
const pageTitle = title ?? dict.meta.title;
const pageDescription = description ?? dict.meta.description;
const favicon = withBase(variant === "error" ? "/favicon-error.svg" : "/favicon.svg");

// liner notes for those who view source ÔÇö the cleanest room in the house
const sourceNote = `
     ÔľłÔľłÔĽŚÔľłÔľłÔĽŚ  ÔľłÔľłÔĽŚÔľłÔľłÔľłÔĽŚ   ÔľłÔľłÔĽŚ      ÔľłÔľłÔľłÔľłÔľłÔľłÔĽŚ  ÔľłÔľłÔľłÔľłÔľłÔľłÔĽŚ  ÔľłÔľłÔľłÔľłÔľłÔľłÔĽŚ
     ÔľłÔľłÔĽĹÔĽÜÔľłÔľłÔĽŚÔľłÔľłÔĽöÔĽŁÔľłÔľłÔľłÔľłÔĽŚ  ÔľłÔľłÔĽĹ     ÔľłÔľłÔĽöÔĽÉÔľłÔľłÔľłÔľłÔĽŚÔľłÔľłÔĽöÔĽÉÔľłÔľłÔľłÔľłÔĽŚÔľłÔľłÔĽöÔĽÉÔľłÔľłÔľłÔľłÔĽŚ
     ÔľłÔľłÔĽĹ ÔĽÜÔľłÔľłÔľłÔĽöÔĽŁ ÔľłÔľłÔĽöÔľłÔľłÔĽŚ ÔľłÔľłÔĽĹ     ÔľłÔľłÔĽĹÔľłÔľłÔĽöÔľłÔľłÔĽĹÔľłÔľłÔĽĹÔľłÔľłÔĽöÔľłÔľłÔĽĹÔľłÔľłÔĽĹÔľłÔľłÔĽöÔľłÔľłÔĽĹ
ÔľłÔľł   ÔľłÔľłÔĽĹ ÔľłÔľłÔĽöÔľłÔľłÔĽŚ ÔľłÔľłÔĽĹÔĽÜÔľłÔľłÔĽŚÔľłÔľłÔĽĹ     ÔľłÔľłÔľłÔľłÔĽöÔĽŁÔľłÔľłÔĽĹÔľłÔľłÔľłÔľłÔĽöÔĽŁÔľłÔľłÔĽĹÔľłÔľłÔľłÔľłÔĽöÔĽŁÔľłÔľłÔĽĹ
ÔĽÜÔľłÔľłÔľłÔľłÔľłÔĽöÔĽŁÔľłÔľłÔĽöÔĽŁ ÔľłÔľłÔĽŚÔľłÔľłÔĽĹ ÔĽÜÔľłÔľłÔľłÔľłÔĽĹ     ÔĽÜÔľłÔľłÔľłÔľłÔľłÔľłÔĽöÔĽŁÔĽÜÔľłÔľłÔľłÔľłÔľłÔľłÔĽöÔĽŁÔĽÜÔľłÔľłÔľłÔľłÔľłÔľłÔĽöÔĽŁ
