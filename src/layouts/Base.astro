---
import "@fontsource-variable/space-grotesk";
import "@fontsource-variable/jetbrains-mono";
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";
import type { Locale } from "@/i18n";
import { getDict } from "@/i18n";
import { withBase } from "@/lib/url";
import Deck from "@/islands/Deck";

interface Props {
  locale: Locale;
  /** Override <title> (404, status). */
  title?: string;
  description?: string;
  /** Error pages: red favicon, no needle drop. */
  variant?: "default" | "error";
}

const { locale, title, description, variant = "default" } = Astro.props;
const dict = getDict(locale);
const pageTitle = title ?? dict.meta.title;
const pageDescription = description ?? dict.meta.description;
const favicon = withBase(variant === "error" ? "/favicon-error.svg" : "/favicon.svg");

// liner notes for those who view source ‚ÄĒ the cleanest room in the house
const sourceNote = `
     ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó      ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
     ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĒ‚ēź‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
     ‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēĎ
‚Ėą‚Ėą   ‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ
‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ     ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ
 ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēĚ      ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ

produced & engineered by Norbert Ol√°h
recorded in Budapest ¬∑ mixed with machines ¬∑ mastered by hand
no cookies ¬∑ no trackers ¬∑ no skill bars

you're reading the source. correct instinct.
the toys are in the deck, bottom right. the terminal also answers to ~
`;
---

<!doctype html>
<html lang={dict.meta.htmlLang} data-side={dict.meta.side}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="author" content="Norbert Ol√°h" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <link rel="author" href={withBase("/humans.txt")} />
    {
      // hreflang pairs ‚ÄĒ EN canonical, structure-identical HU
      variant === "default" && (
        <>
          <link rel="alternate" hreflang="en" href={withBase("/en")} />
          <link rel="alternate" hreflang="hu" href={withBase("/hu")} />
        </>
      )
    }

    <ClientRouter />

    {/* needle-drop gate: runs before paint, no flash for returning visitors */}
    <script is:inline>
      (function () {
        var reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (reduced || sessionStorage.getItem("jxn.dropped")) {
          document.documentElement.classList.add("dropped");
        }
      })();
    </script>

    {/* the dropped flag lives on <html>, which the router swaps ‚ÄĒ restore it */}
    <script is:inline>
      document.addEventListener("astro:page-load", function () {
        if (sessionStorage.getItem("jxn.dropped")) {
          document.documentElement.classList.add("dropped");
        }
      });
    </script>
  </head>
  <body>
    <Fragment set:html={`<!--${sourceNote}-->`} />

    {
      variant === "default" && (
        <div id="needle" aria-hidden="true">
          <div class="nd-inner">
            <span class="nd-type nd-cursor" />
            <div class="nd-wave" />
          </div>
        </div>
      )
    }

    <a class="bracket skip-link" href="#main">{dict.ui.skipToContent}</a>

    <slot />

    <div id="toast" role="status" aria-live="polite"></div>
    <pre id="cat-walk" aria-hidden="true"></pre>

    {/* the record flip cover ‚ÄĒ persisted so it survives the page swap it covers */}
    <div id="flip-cover" aria-hidden="true" transition:persist>
      <div class="flip-cover-inner">
        <span class="flip-mark">JXN-000</span>
        <span class="flip-sub">flipping the record</span>
      </div>
    </div>

    {/* the deck: visible toys, persisted across the flip */}
    <Deck client:idle transition:persist="deck" transition:persist-props />

    {variant === "default" && <script>import "@/scripts/needle";</script>}
    <script>import "@/scripts/eggs";</script>
    <script>import "@/scripts/flip";</script>

    <style>
      .skip-link {
        position: absolute;
        top: -3rem;
        left: var(--gutter);
        z-index: 100;
        background: var(--bg-2);
        padding: 0.5rem 0.8rem;
        transition: top var(--beat-quarter) var(--ease-out);
      }
      .skip-link:focus-visible {
        top: 0.5rem;
      }
    </style>
  </body>
</html>
