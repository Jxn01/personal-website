---

<!doctype html>
<html lang={dict.meta.htmlLang} data-side={dict.meta.side}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="author" content="Norbert Ol√°h" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <link rel="author" href="/humans.txt" />
    {
      // hreflang pairs ‚ÄĒ EN canonical, structure-identical HU
      variant === "default" && (
        <>
          <link rel="alternate" hreflang="en" href="/en" />
          <link rel="alternate" hreflang="hu" href="/hu" />
        </>
      )
    }

    {/* needle-drop gate: runs before paint, no flash for returning visitors */}
    <script is:inline>
      (function () {
        var reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (reduced || sessionStorage.getItem("jxn.dropped")) {
          document.documentElement.classList.add("dropped");
        }
      })();
    </script>

    {/* the record flip: only SIDE A ‚ÜĒ SIDE B navigations get the theatrics */}
    <script is:inline>
      window.addEventListener("pagereveal", function (e) {
        if (!e.viewTransition) return;
        var from = window.navigation?.activation?.from?.url;
        if (!from) return;
        var was = new URL(from).pathname.split("/")[1];
        var is_ = location.pathname.split("/")[1];
        var locales = ["en", "hu"];
        if (locales.includes(was) && locales.includes(is_) && was !== is_) {
          document.documentElement.dataset.vt = "flip";
        } else {
          e.viewTransition.skipTransition();
        }
      });
    </script>
  </head>
  <body>
    <Fragment set:html={`<!--${sourceNote}-->`} />

    {
      variant === "default" && (
        <div id="needle" aria-hidden="true">
          <div class="nd-inner">
            <span class="nd-type nd-cursor" />
            <div class="nd-wave" />
          </div>
        </div>
      )
    }

    <a class="bracket skip-link" href="#main">{dict.ui.skipToContent}</a>

    <slot />

    <div id="toast" role="status" aria-live="polite"></div>
    <pre id="cat-walk" aria-hidden="true"></pre>

    {variant === "default" && <script>import "@/scripts/needle";</script>}
    <script>import "@/scripts/eggs";</script>

    <style>
      .skip-link {
        position: absolute;
        top: -3rem;
        left: var(--gutter);
        z-index: 100;
        background: var(--bg-2);
        padding: 0.5rem 0.8rem;
        transition: top var(--beat-quarter) var(--ease-out);
      }
      .skip-link:focus-visible {
        top: 0.5rem;
      }
    </style>
  </body>
</html>
