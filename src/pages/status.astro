---
import Base from "@/layouts/Base.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import StatusPanel from "@/islands/StatusPanel";

/**
 * The engine room as a standalone page (deep-linkable). The deck opens the
 * same panel as a modal — same component, zero duplication.
 */
---

<Base locale="en" title="JXN-000 — status" description="System status for JXN-000.">
  <Header locale="en" />

  <main id="main" class="container track">
    <div class="window">
      <div class="window-bar">
        <span>jxn-000 — system status</span>
        <span class="win-controls"><span>—</span><span>□</span><span>×</span></span>
      </div>
      <StatusPanel client:load />
    </div>
  </main>

  <Footer locale="en" />
</Base>
