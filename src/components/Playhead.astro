---
/**
 * The playhead. Scroll position rendered as track position. The page is the
 * record; the scrollbar is the needle. Nobody explains it.
 */
---

<div class="playhead" id="playhead" aria-hidden="true">
  <div class="ph-row">
    <span class="ph-track" id="ph-track"></span>
    <span id="ph-time">00:00 / 00:00</span>
  </div>
  <div class="ph-rail" id="ph-rail">
    <div class="ph-bar" id="ph-bar"></div>
  </div>
</div>

<script>
  // ClientRouter-aware: module runs once, state re-binds on every page-load
  interface Mark {
    el: HTMLElement;
    label: string;
    frac: number;
  }

  const mmss = (s: number): string =>
    `${String(Math.floor(s / 60)).padStart(2, "0")}:${String(Math.floor(s % 60)).padStart(2, "0")}`;

  const state = {
    bar: null as HTMLElement | null,
    time: null as HTMLElement | null,
    trackLabel: null as HTMLElement | null,
    rail: null as HTMLElement | null,
    marks: [] as Mark[],
    total: 0,
  };

  function measure(): void {
    if (!state.rail) return;
    const sections = [...document.querySelectorAll<HTMLElement>("[data-track]")];
    const scrollable = document.documentElement.scrollHeight - innerHeight;
    if (scrollable <= 0) return;
    state.marks = sections.map((el) => ({
      el,
      label: `${el.dataset.no} — ${el.dataset.title}`,
      frac: Math.min(1, el.offsetTop / scrollable),
    }));
    state.rail.querySelectorAll(".ph-tick").forEach((t) => t.remove());
    for (const m of state.marks.slice(1)) {
      const tick = document.createElement("button");
      tick.className = "ph-tick";
      tick.style.left = `${(m.frac * 100).toFixed(2)}%`;
      tick.title = m.label;
      tick.setAttribute("aria-label", m.label);
      tick.addEventListener("click", () => m.el.scrollIntoView({ behavior: "smooth" }));
      state.rail.appendChild(tick);
    }
  }

  let raf = 0;
  function update(): void {
    raf = 0;
    if (!state.bar) return;
    const scrollable = document.documentElement.scrollHeight - innerHeight;
    const p = scrollable > 0 ? Math.min(1, Math.max(0, scrollY / scrollable)) : 0;
    state.bar.style.width = `${(p * 100).toFixed(2)}%`;
    if (state.time) {
      state.time.textContent = `${mmss(state.total * p)} / ${mmss(state.total)}`;
    }
    if (state.trackLabel) {
      let current = state.marks[0];
      for (const m of state.marks) if (p >= m.frac - 0.001) current = m;
      if (current && state.trackLabel.textContent !== current.label) {
        state.trackLabel.textContent = current.label;
      }
    }
  }

  function init(): void {
    state.bar = document.getElementById("ph-bar");
    state.time = document.getElementById("ph-time");
    state.trackLabel = document.getElementById("ph-track");
    state.rail = document.getElementById("ph-rail");
    if (!state.bar) return; // page without a playhead
    const sections = [...document.querySelectorAll<HTMLElement>("[data-track]")];
    state.total = sections.reduce((acc, el) => acc + Number(el.dataset.secs ?? 0), 0);
    measure();
    update();
  }

  addEventListener(
    "scroll",
    () => {
      if (!raf) raf = requestAnimationFrame(update);
    },
    { passive: true },
  );
  addEventListener("resize", () => {
    measure();
    update();
  });

  init();
  document.addEventListener("astro:page-load", init);
</script>
