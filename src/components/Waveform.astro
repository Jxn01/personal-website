---
/**
 * Waveform divider — a 1px rule with slight amplitude. Static, seeded,
 * different for every track gap. Not an audio player. Never an audio player.
 */
interface Props {
  seed?: number;
}

const { seed = 1 } = Astro.props;

// deterministic per-divider waveform (mulberry32)
function rng(s: number) {
  return () => {
    s |= 0;
    s = (s + 0x6d2b79f5) | 0;
    let t = Math.imul(s ^ (s >>> 15), 1 | s);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const rand = rng(seed * 7919);
const W = 1200;
const MID = 12;
const points: string[] = [`0,${MID}`];
for (let x = 24; x < W; x += 12) {
  // mostly flat line, occasional pockets of amplitude — a groove, not a graph
  const burst = rand() > 0.72;
  const amp = burst ? (rand() - 0.5) * 14 : (rand() - 0.5) * 2.4;
  points.push(`${x},${(MID + amp).toFixed(1)}`);
}
points.push(`${W},${MID}`);
---

<svg
  class="waveform"
  viewBox={`0 0 ${W} 24`}
  preserveAspectRatio="none"
  aria-hidden="true"
>
  <polyline
    points={points.join(" ")}
    fill="none"
    stroke="currentColor"
    stroke-width="1"
  ></polyline>
</svg>
