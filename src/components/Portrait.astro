---
import { Image } from "astro:assets";
import portrait from "@/assets/portrait.jpeg";

/**
 * The portrait. Warm human on a cold site = intended tension (spec 1.2).
 * Duotone via two CSS blend layers (proven to render): a color-tint of the
 * live accent + a shade that seats the shadows in page-black. So the photo
 * re-inks with the side and the mixer. Halftone dots + scanlines for the
 * print register; a gold wash where the chain catches light.
 *
 * Sizing: the figure caps its own width and clips, so the image (normal flow,
 * its own ratio) can never escape — fixes the iOS overflow without the
 * aspect-ratio/absolute combo that refused to paint.
 */
interface Props {
  label: string;
}
const { label } = Astro.props;
---

<figure class="portrait reveal" aria-label={label}>
  <div class="portrait-frame">
    <Image
      src={portrait}
      alt="Norbert Oláh"
      widths={[300, 450, 600]}
      sizes="(max-width: 840px) 78vw, 300px"
      class="portrait-img"
      loading="lazy"
    />
    <span class="portrait-tint" aria-hidden="true"></span>
    <span class="portrait-shade" aria-hidden="true"></span>
    <span class="portrait-dots" aria-hidden="true"></span>
    <span class="portrait-scan" aria-hidden="true"></span>
    <span class="portrait-glint" aria-hidden="true"></span>
  </div>
  <figcaption class="stamp">{label}</figcaption>
</figure>

<style>
  .portrait {
    position: relative;
    border: 1px solid var(--line-0);
    background: var(--bg-2);
    padding: 0.5rem;
    display: grid;
    gap: 0.6rem;
    /* deterministic width on every screen; clip is the safety net */
    width: 100%;
    max-width: 300px;
    overflow: hidden;
    justify-self: start;
  }

  /* sleeve-mount: image inset in a flat field. The image (normal flow) sizes
     the frame by its own ratio; the figure above caps + clips it. */
  .portrait-frame {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius);
    background: var(--bg-0);
    isolation: isolate;
    line-height: 0;
  }

  .portrait-img {
    display: block;
    width: 100%;
    height: auto;
    filter: grayscale(1) contrast(1.1) brightness(1.04);
    /* always visible (never gated behind JS); the resolve is a gentle settle */
    opacity: 1;
    scale: 1.05;
    transition: scale var(--beat) var(--ease-out);
  }

  :global(.portrait.in) .portrait-img {
    scale: 1;
  }

  /* the duotone ink: live accent, blended as color — follows side + mixer */
  .portrait-tint {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: var(--accent);
    mix-blend-mode: color;
  }

  /* seat the shadows back into the page's near-black */
  .portrait-shade {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    background: var(--bg-0);
    mix-blend-mode: multiply;
    opacity: 0.2;
  }

  /* halftone dot screen — the print artifact */
  .portrait-dots {
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    background-image: radial-gradient(
      color-mix(in oklab, var(--cream) 40%, transparent) 28%,
      transparent 29%
    );
    background-size: 4px 4px;
    mix-blend-mode: overlay;
    opacity: 0.35;
  }

  .portrait-scan {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0 2px,
      rgba(0, 0, 0, 0.16) 3px,
      transparent 4px
    );
    opacity: 0.5;
  }

  /* the chain glint — soft gold where the necklace catches light */
  .portrait-glint {
    position: absolute;
    inset: 0;
    z-index: 6;
    pointer-events: none;
    background: radial-gradient(
      ellipse 38% 16% at 52% 82%,
      color-mix(in oklab, var(--gold) 42%, transparent),
      transparent 70%
    );
    mix-blend-mode: screen;
  }

  .portrait figcaption {
    justify-self: start;
  }

  @media (prefers-reduced-motion: reduce) {
    .portrait-img {
      scale: 1;
      transition: none;
    }
  }
</style>
